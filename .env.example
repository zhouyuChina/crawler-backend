# Server
NODE_ENV=development
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=crm_db

# Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# CORS
CORS_ORIGIN=*

# 抓取配置管理页面账密（必填，否则配置页面不可用）
CRAWL_ADMIN_USERNAME=admin
CRAWL_ADMIN_PASSWORD=changeme

# 需人工验证时 Telegram 通知（多个 chat_id 用英文逗号分隔，含群和私聊）
# 私聊 id：先给 bot 发 /start，再访问 getUpdates 获取
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=-1003442178384,8681896965
