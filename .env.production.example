# Server
NODE_ENV=production
PORT=3000

# Database
# Docker Compose 快速部署默认使用内置 PostgreSQL 服务
DB_HOST=db
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=crm_db
DB_SYNCHRONIZE=true
DB_LOGGING=false

# Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# CORS
# 对外公开前请改成实际前端域名
CORS_ORIGIN=*
