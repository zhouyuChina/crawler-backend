# Server
NODE_ENV=production
PORT=3000

# Database
DB_HOST=your-production-db-host
DB_PORT=5432
DB_USERNAME=your-db-username
DB_PASSWORD=your-strong-password
DB_DATABASE=crm_db

# Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# CORS (生产环境请指定具体域名，不要使用 *)
CORS_ORIGIN=https://your-frontend-domain.com
